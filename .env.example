# ── Required for chat (OpenRouter) ──────────────────────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional OpenRouter metadata (shown on openrouter.ai dashboard)
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_APP_NAME=Medical RAG System

# ── LLM provider: openrouter (deploy) or ollama (local) ───────────────────
LLM_PROVIDER=openrouter

# ── Embeddings: local (free, runs on CPU) | openrouter | ollama ─────────────
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Auth: set to 1 to skip Firebase (recommended for demo/deploy) ───────────
DISABLE_AUTH=1

# ── Ollama fallback (only if LLM_PROVIDER=ollama) ───────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434

# ── Firebase (only if DISABLE_AUTH=0) ───────────────────────────────────────
# GOOGLE_APPLICATION_CREDENTIALS=firebase_service_account.json
